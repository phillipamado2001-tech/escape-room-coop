# Escape Room Co-op — Environment Variables
# Copy this to .env.local and fill in your keys

# Anthropic API Key (for Opus room generation + Sonnet hints)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key (for DALL-E 3 asset generation — optional, can use pre-built assets)
OPENAI_API_KEY=sk-your-key-here

# Server config
SERVER_PORT=3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Game config
DEFAULT_HINT_POLICY=limited
DEFAULT_HINTS_AVAILABLE=8
MAX_SESSION_DURATION_MINUTES=60
